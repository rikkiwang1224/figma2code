# Figma API
FIGMA_API_KEY=your_figma_api_key

# Claude API (Anthropic or compatible gateway)
ANTHROPIC_API_KEY=your_api_key
FIGMA2CODE_MODEL=claude-sonnet-4-5
FIGMA2CODE_MAX_TOKENS=16000
FIGMA2CODE_ENABLE_STREAMING=true

# Agent mode: merged-query (default) | legacy
FIGMA2CODE_AGENT_MODE=merged-query

# Output directories (relative to cwd when running CLI)
FIGMA2CODE_OUTPUT_DIR=./output
FIGMA2CODE_REPORTS_DIR=./reports

# Optional: custom agent cwd (skills live under .claude/skills/)
# FIGMA2CODE_AGENT_CWD=./packages/core
